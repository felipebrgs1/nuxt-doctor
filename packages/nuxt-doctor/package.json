{
  "name": "nuxt-doctor",
  "version": "0.0.1",
  "description": "Diagnose and fix performance issues in your Nuxt / Vue app",
  "keywords": ["diagnostics", "linter", "nuxt", "vue", "performance"],
  "homepage": "https://github.com/felipeb/nuxt-doctor#readme",
  "bugs": { "url": "https://github.com/felipeb/nuxt-doctor/issues" },
  "license": "MIT",
  "author": "Felipe B",
  "repository": {
    "type": "git",
    "url": "https://github.com/felipeb/nuxt-doctor.git",
    "directory": "packages/nuxt-doctor"
  },
  "bin": { "nuxt-doctor": "./dist/cli.js" },
  "files": ["dist"],
  "type": "module",
  "exports": {
    ".": { "types": "./dist/cli.d.ts", "default": "./dist/cli.js" },
    "./api": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./browser": { "types": "./dist/browser.d.ts", "default": "./dist/browser.js" },
    "./oxlint-plugin": { "types": "./dist/nuxt-doctor-plugin.d.ts", "default": "./dist/nuxt-doctor-plugin.js" },
    "./worker": { "types": "./dist/worker.d.ts", "default": "./dist/worker.js" }
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "rm -rf dist && NODE_ENV=production vp pack",
    "typecheck": "tsc --noEmit",
    "test": "vp test run"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "knip": "^6.3.1",
    "ora": "^9.3.0",
    "oxlint": "^1.60.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "typescript": ">=5.0.4 <7"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9"
  }
}
